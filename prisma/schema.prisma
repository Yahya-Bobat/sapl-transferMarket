// Pro Clubs Transfer Market - LeagueRepublic data + listing
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Auth: sign in with phone (dialing code + number)
  authPhone    String?  @unique // normalized digits, e.g. 27718665667
  passwordHash String?

  // LeagueRepublic CSV fields (PERSON_3377)
  personId    String   @unique // Person ID from LeagueRepublic
  role        String   @default("Starter")
  teams       String?  // comma-separated or single
  activeFrom  String?
  activeTo    String?
  userName    String?  // LeagueRepublic User Name (gamer tag)
  lastName    String?
  firstName   String?
  email       String?
  workPhone   String?
  homePhone   String?
  mobilePhone String?
  status      String?  @default("Active")
  dob         String?
  houseNo     String?
  houseName   String?
  addr1       String?
  addr2       String?
  addr3       String?
  city        String?
  county      String?
  postcode    String?
  internalRef1 String?
  internalRef2 String?

  // Transfer market relations
  trialRequestsAsPlayer TrialRequest[] @relation("PlayerRequests")

  // Transfer market fields
  listed             Boolean  @default(false) // only show in market when true
  listedAt           DateTime? // when the listing was last bumped (24h cooldown)
  gamertag           String?  // display on market (e.g. PSN/EA tag) instead of userName when set
  platform           String?  // PC | PS5 | Xbox
  preferredPositions String   @default("[]") // JSON array e.g. ["ST","CAM","CM"]
  preferredLeagues   String   @default("[]") // JSON array of league names
  bio                String?  // optional short bio
  previousClub       String?  // most recent club, blank = free agent
}

model PendingOtp {
  id        String   @id @default(cuid())
  phone     String   @unique // normalized e.g. 27718665667
  code      String   // 6 digits
  expiresAt DateTime
}

model Captain {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  email        String   @unique
  passwordHash String
  teamName     String?  // e.g. "Azzurri Esports"
  authPhone    String?  // phone used for OTP verification (digits only, e.g. 27718665667)

  // Approval status: pending | approved | rejected
  // Default "approved" so existing captains aren't locked out when column is added.
  // New captains are explicitly set to "pending" in the register API.
  approvalStatus String @default("approved")

  // Whether the captain is listed on the market
  listed Boolean @default(false)
  listedAt DateTime? // when the listing was last bumped (24h cooldown)

  // Looking-for-player listing fields (used to generate WhatsApp posts)
  platform           String?
  preferredLeagues   String   @default("[]") // JSON array
  preferredPositions String   @default("[]") // JSON array
  role               String?  // role they need: Starter | Rotation
  clubStatus         String?  // Free agents only | Will pay transfer fee (R200) | Open to both
  trialGroupLink     String?  // WhatsApp trial group invite link
  requirements       String?  // free-text requirements / extra info
  whatsappNumber     String?  // captain's contact number for the post

  trialRequests TrialRequest[]
  resetToken    CaptainResetToken?
}

model Admin {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  email        String   @unique
  passwordHash String
}

model TrialRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  captainId String
  captain   Captain  @relation(fields: [captainId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation("PlayerRequests", fields: [playerId], references: [id], onDelete: Cascade)
  message   String?  // optional message from captain
  status    String   @default("pending") // pending | accepted | declined

  @@unique([captainId, playerId])
}

model CaptainResetToken {
  id        String   @id @default(cuid())
  captainId String   @unique
  captain   Captain  @relation(fields: [captainId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
}

model PendingPlayerRegistration {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Info submitted by the applicant
  firstName   String
  lastName    String
  dialingCode String   @default("27")
  phoneNumber String   // raw input as entered
  email       String?
  personId    String?  // LeagueRepublic Person ID if they know it
  teamName    String?  // which SAPL team they play for
  notes       String?  // free text explanation

  // Admin resolution
  status         String   @default("pending") // pending | approved | rejected
  adminNotes     String?
  linkedPlayerId String?  // Player.id if admin links to existing record
  reviewedAt     DateTime?
}
